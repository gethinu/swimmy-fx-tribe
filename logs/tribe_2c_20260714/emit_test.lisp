(load "logs/tribe_2c_20260714/emit_forms.lisp")
(in-package :swimmy.school)
(let ((kelt (make-strategy :name "K" :indicators '((keltner 50 2)) :sl 0.005d0 :tp 0.005d0
                           :timeframe 240 :band-mult 2.5d0 :atr-period 14
                           :atr-barrier-sl 2.0d0 :atr-barrier-tp 3.0d0)))
  (setf *enable-primitive-diversity* nil)
  (let ((off (strategy-to-alist kelt)))
    (assert (null (assoc 'band_mult off)) () "OFF no band_mult")
    (assert (eq (cdr (assoc 'indicator_type off)) 'sma) () "OFF keltner->sma"))
  (setf *enable-primitive-diversity* t)
  (let ((on (strategy-to-alist kelt)))
    (assert (eq (cdr (assoc 'indicator_type on)) 'keltner) () "ON keltner")
    (assert (= (cdr (assoc 'sma_short on)) 50) () "ON sma_short=period 50, got ~a" (cdr (assoc 'sma_short on)))
    (assert (= (cdr (assoc 'band_mult on)) 2.5) () "ON band_mult 2.5")
    (assert (= (cdr (assoc 'atr_barrier_sl on)) 2.0) () "ON atr_barrier_sl")
    (assert (= (cdr (assoc 'atr_barrier_tp on)) 3.0) () "ON atr_barrier_tp"))
  ;; legacy byte-identity for a plain SMA pair across the flag (short/long unchanged)
  (let ((sma (make-strategy :name "S" :indicators '((sma 30) (sma 60)) :sl 0.5d0 :tp 0.5d0 :timeframe 60)))
    (setf *enable-primitive-diversity* nil)
    (let ((off (strategy-to-alist sma)))
      (setf *enable-primitive-diversity* t)
      (let ((on (strategy-to-alist sma)))
        (assert (= (cdr (assoc 'sma_short off)) (cdr (assoc 'sma_short on))) () "SMA short stable")
        (assert (= (cdr (assoc 'sma_long off)) (cdr (assoc 'sma_long on))) () "SMA long stable")
        (assert (eq (cdr (assoc 'indicator_type off)) (cdr (assoc 'indicator_type on))) () "SMA type stable")
        (assert (null (assoc 'band_mult off)) () "SMA OFF no ext"))))
  (format t "~&EMIT-TEST-PASS: keltner period=50 emitted; OFF legacy byte-stable; ON full extension~%"))
(sb-ext:exit :code 0)
