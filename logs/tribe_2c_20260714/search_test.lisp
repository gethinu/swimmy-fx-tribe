(load "logs/tribe_2c_20260714/search_forms.lisp")
(in-package :swimmy.school)
;; 1. OFF regime mapping byte-identical to legacy for all categories
(setf *enable-primitive-diversity* nil)
(dolist (cat '(:trend :reversion :breakout :scalp :unknown))
  (assert (eq (breeder-mutation-regime cat) (breeder-legacy-regime cat)) ()
          "OFF regime must equal legacy for ~a" cat))
;; 2. diverse genes in the forward-robust neighbourhood
(dotimes (i 200)
  (let* ((g (make-diverse-primitive-genes :breakout))
         (ind (car (getf g :indicators))))
    (assert (eq (car ind) 'keltner) () "breakout -> keltner")
    (assert (<= 40 (cadr ind) 64) () "period 40..64 got ~a" (cadr ind))
    (assert (<= 1.5 (getf g :band-mult) 2.5) () "band-mult 1.5..2.5")
    (assert (member (getf g :atr-barrier-sl) '(2.0 3.0) :test #'=) () "atr 2 or 3")))
;; 3. a diverse child EMITS as keltner/bb with period=sma_short and genes present (flag ON)
(setf *enable-primitive-diversity* t)
(let* ((p1 (make-strategy :name "P1" :indicators '((sma 30)(sma 60)) :category :trend))
       (p2 (make-strategy :name "P2" :indicators '((ema 20)) :category :trend))
       (n 0))
  (dotimes (i 100)
    (let* ((child (make-diverse-child p1 p2 5 (format nil "D~d" i) :both "EURUSD" 0.005d0 0.005d0))
           (al (strategy-to-alist child))
           (typ (cdr (assoc 'indicator_type al)))
           (short (cdr (assoc 'sma_short al))))
      (assert (member typ '(keltner bb) ) () "diverse child emits keltner/bb, got ~a" typ)
      (assert (= short (cadr (car (strategy-indicators child)))) () "sma_short = primitive period")
      (assert (assoc 'band_mult al) () "diverse child emits band_mult")
      (assert (member (strategy-timeframe child) '(240 360)) () "H4/H6 tf")
      (when (eq typ 'keltner) (incf n))))
  (format t "~&SEARCH-TEST-PASS: OFF regime==legacy; genes in FR-neighbourhood; ~d/100 diverse children keltner, rest bb; all emit primitive+genes~%" n))
(sb-ext:exit :code 0)
